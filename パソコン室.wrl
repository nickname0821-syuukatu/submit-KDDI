DEF tukueTouch TouchSensor{
}
DEF tukueTimer TimeSensor{
cycleInterval 2.0
loop TRUE
startTime 0.0
stopTime 0.1
}
DEF tukueColor ColorInterpolator{
key[ 0., 0.33,0.66, 1.]
keyValue[ 1 0.0 0.0, # 時刻0のRGB

0 1 0, 
0 0 1,
1 0 0 ] # 時刻1のRGB(時刻0と一致させている)
}
ROUTE tukueTouch.touchTime TO tukueTimer.set_startTime
ROUTE tukueTimer.fraction_changed TO tukueColor.set_fraction
ROUTE tukueColor.value_changed TO tukueFacade.set_diffuseColor
