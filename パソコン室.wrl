#VRML V2.0 utf8
# points
        Shape {
            appearance Appearance {
                material Material {
                    diffuseColor 0.0 1.0 0.0
                    emissiveColor 0.0 1.0 0.0
                }
            }
            geometry PointSet {
                coord Coordinate {
                    point [
                        0.0 0.0 0.0, 
                    ]
                }
            }
        }
#チュー王子
DEF Monolith Transform{
children[
Transform{
    translation 8 0.5 5.7
rotation 0 -1 0 1.57
scale 1.7 1.7 1.7
    children[Inline{
         url "Chuoji1124.wrl"
      }
Shape{appearance Appearance {
material DEF AFacade Material {}

      
   } }]
}]}
DEF ATouch TouchSensor {}
DEF ATimer TimeSensor {
cycleInterval 8.0
loop TRUE
startTime 0.0
stopTime 0.1
}
DEF APosition PositionInterpolator{
key[0, 0.125, 0.25, 0.375, 0.5, 0.625, 0.75, 0.875, 1.0]
keyValue[ 0. 0. 0., -5. 0. 0., -5. 0. 3.6, -13. 0. 3.6, -13. 0. 3.6,-13. 0. 3.6,
 -5. 0. 3.6, -5. 0. 0., 0. 0. 0 ]
}
ROUTE ATouch.touchTime TO ATimer.set_startTime
ROUTE ATimer.fraction_changed TO APosition.set_fraction
ROUTE APosition.value_changed TO Monolith.set_translation
