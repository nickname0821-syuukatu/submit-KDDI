# A cylinder
Transform{
	translation 2 2 3.333
	rotation 0 0 0 0
	scale 1 2 1
	children[
	  Shape{
		appearance Appearance{
			material Material{diffuseColor 1 1 1
				emissiveColor 0.0 0.0 0.0
				transparency 0.0
				specularColor 0 0.0 0
				shininess 0
				ambientIntensity 0}
		}
		geometry Cylinder {
			height 2
			radius 0.5
			bottom TRUE
			top TRUE
			side TRUE
		}
	  }
	]
}
